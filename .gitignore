.Rproj.user
.Rhistory
.RData
.Ruserdata
*.o
*.so
*.dll
src/symbols.rds
.DS_Store

# R CMD build / check artifacts
/*.tar.gz
/*.Rcheck/

# Generated by ./configure from src/Makevars.in (plus conftest probe debris).
# Never commit src/Makevars: a committed copy alongside src/Makevars.in trips
# the "both Makevars.in and Makevars" R CMD check NOTE. configure regenerates
# it at install; the top-level cleanup script removes it afterwards.
/src/Makevars
/conftest
/conftest.c

# dev/ is tracked on the `dev` branch and stripped by the ship script
# before promotion to `main`. The outer .gitignore intentionally does
# not hide dev/ here so its contents live alongside package sources on
# the dev branch.

# babysitter/a5c runs and state
.a5c/

# Claude Code session state
.claude/

# git worktrees for isolated agent work
.worktrees/

# testthat recovery artifacts (written on test failure, not source-controlled)
tests/testthat/_problems/
tests/testthat/testthat-problems.rds
/doc/
/Meta/
