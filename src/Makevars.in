# Template for src/Makevars, generated by ./configure (and src/Makevars.win by
# ./configure.win). src/Makevars is NOT committed - configure regenerates it at
# install and the top-level cleanup script removes it, so the package never
# ships both Makevars.in and a Makevars (which trips an R CMD check NOTE).
# configure substitutes @DAFR_SHARD_*@ when a system c-blosc / libzstd is found,
# enabling packed/sharded ZarrDaf read; absent either, the flat path is built.
PKG_CPPFLAGS = @DAFR_SHARD_CPPFLAGS@
PKG_CXXFLAGS = -DDAFR_HAVE_MMAP=1 $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -lz @DAFR_SHARD_LIBS@
CXX_STD = CXX17
