# Generated from src/Makevars.in by ./configure. The committed src/Makevars is
# a no-optional-lib fallback so source installs that skip configure still build
# the flat ZarrDaf path. configure substitutes @DAFR_SHARD_*@ when a system
# c-blosc / libzstd is found, enabling packed/sharded read.
PKG_CPPFLAGS = @DAFR_SHARD_CPPFLAGS@
PKG_CXXFLAGS = -DDAFR_HAVE_MMAP=1 $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -lz @DAFR_SHARD_LIBS@
CXX_STD = CXX17
